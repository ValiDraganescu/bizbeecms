{
  "$schema": "node_modules/wrangler/config-schema.json",
  // The PM provisions one CMS Worker per Site; the deploy task will override
  // `name` per-Site (e.g. bizbeecms-cms-<site-slug>) via the Cloudflare API.
  "name": "bizbeecms-cms",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-25",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Per-Site D1 database. Each deployed CMS Worker gets its OWN D1 (the database
  // IS the Site boundary). `database_id` is a placeholder zero-id here — the PM
  // deploy step provisions a real D1 per Site and overrides it. Run migrations
  // with `wrangler d1 migrations apply <name>` after creation.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "bizbeecms-cms",
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],
  // Workers AI binding for the per-Site AI assistant (Milestone 2, epic B1).
  // No API key — billed via Cloudflare. The chat route calls `env.AI.run(...)`
  // through AI Gateway (caching / per-Site spend caps / analytics / fallback).
  // The gateway slug is read from the AI_GATEWAY var (code has a fallback).
  "ai": {
    "binding": "AI"
  },
  // Per-Site R2 bucket for media assets (Milestone 2, epic D1). The upload
  // route writes bytes here; `/media/<key>` streams them back. Each deployed
  // CMS Worker gets its OWN bucket (the bucket IS the Site boundary). The PM
  // deploy step provisions a real bucket per Site and overrides bucket_name.
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "bizbeecms-cms-media"
    }
  ],
  "vars": {
    "AI_GATEWAY": "bizbeecms-ai-gateway",
    // CMS admin-auth bridge (Sec1). The deployer OVERRIDES these per-Site at
    // `wrangler deploy` time (via --var); the placeholders here just declare the
    // shape and let the build/typegen see them.
    //  - SITE_ID: this CMS's Site id (the PM cms-validate reach check is run
    //    against it). Empty placeholder = guard treats the CMS as unconfigured
    //    and DENIES all admin access (fail-closed) until the deployer sets it.
    //  - PM_ORIGIN: the ProjectManager origin that hosts /api/auth/cms-validate.
    //  - CMS_AUTH_SECRET: shared bearer PM checks (peer of DEPLOYER_SECRET). It's
    //    a secret in practice — the deployer injects the real value; never commit
    //    a real one here.
    //  - OPENROUTER_API_KEY: the AI provider key (ai-openrouter). Empty here =>
    //    getAi() falls back to the CF `AI` binding; the deployer injects the real
    //    key per-Site so OpenRouter becomes the active provider. Secret in
    //    practice — never commit a real one.
    //  - APP_ORIGIN: this CMS's own public origin, used to build trusted
    //    invite-accept links (cms-auth Slice 4). The deployer injects the
    //    per-Site worker URL. Empty here => dev falls back to the request host;
    //    production refuses to guess (Host Header Injection guard).
    //  - GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: the CMS's OWN Google OAuth 2.0
    //    client (cms-auth Slice 2b "Sign in with Google"). Empty here => the
    //    Google button is hidden + the start/callback routes no-op. The deployer
    //    injects the real values per-Site; secrets in practice — never commit
    //    real ones. The id_token email is verified server-side (no self-signup).
    "SITE_ID": "",
    "PM_ORIGIN": "",
    "CMS_AUTH_SECRET": "",
    "OPENROUTER_API_KEY": "",
    "APP_ORIGIN": "",
    "GOOGLE_CLIENT_ID": "",
    "GOOGLE_CLIENT_SECRET": ""
  },
  // Cloudflare Email Sending binding for transactional invite emails (cms-auth
  // Slice 4). COMMENTED until a verified sender domain is onboarded on a Paid
  // plan (`wrangler email sending enable <domain>`); until then the invite flow
  // degrades to logging the accept link (see lib/mail/send-invite.ts). When
  // enabling: uncomment, set a real `destination_address`/sender domain, and
  // rerun typegen so `env.EMAIL` is typed.
  // "send_email": [{ "name": "EMAIL" }],
  "observability": {
    "enabled": true
  }
}
